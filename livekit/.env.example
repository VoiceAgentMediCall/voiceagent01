# --- LiveKit server (room auth + WSS URL) ---
# Get from your LiveKit Cloud project page or self-hosted server config.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sarvam (STT + TTS + LLM, single key) ---
# Get from https://dashboard.sarvam.ai/ → API keys.
SARVAM_API_KEY=sk_sarvam_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Dashboard webhook for end-of-call-report POST (B6) ---
# Next.js dashboard endpoint that receives the JSON payload. Required — the
# agent raises and skips the POST loudly if this is unset (no silent fallback
# to the retired Apps Script URL).
DASHBOARD_WEBHOOK_URL=https://medicall-next-app.up.railway.app/api/webhook/livekit

# --- Langfuse tracing (optional; agent runs without these set) ---
# If LANGFUSE_PUBLIC_KEY is empty, @observe decorators become no-ops.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Per-call variables (fallback when admin-panel/prompts.yaml is missing) ---
# In production these are injected per-call (job metadata) or read from prompts.yaml.
PARENT_NAME=Sharma
DRUG_NAME=Metformin
PHONE=+919999999999
